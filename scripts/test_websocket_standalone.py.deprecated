#!/usr/bin/env python3
"""
Test isole du WebSocket vLLM Realtime (correction expert #8).
Verifie que le serveur repond et qu'un court WAV 16 kHz produit du texte.
A executer AVANT l'integration run_multi_model.py.

Usage:
  python scripts/test_websocket_standalone.py tests/test1.wav
  python scripts/test_websocket_standalone.py tests/test1.wav --host localhost --port 8000

Pre-requis:
  - Serveur vLLM lance : bash scripts/start_voxtral_realtime_vllm.sh
  - websockets installe : pip install websockets
"""

import argparse
import asyncio
import base64
import json
import os
import sys
import urllib.request

try:
    import websockets
except ImportError:
    print("ERREUR : websockets non installe.")
    print("  pip install websockets")
    sys.exit(1)

try:
    import librosa
    import numpy as np
except ImportError:
    print("ERREUR : librosa non installe.")
    print("  pip install librosa")
    sys.exit(1)


async def test_realtime(host, port, audio_path, model, subchunk_size):
    url = f"ws://{host}:{port}/v1/realtime"

    print(f"[TEST] Chargement audio : {audio_path}")
    audio_data, sr = librosa.load(audio_path, sr=16000, mono=True)
    audio_data = audio_data.astype(np.float32)
    peak = max(abs(audio_data.max()), abs(audio_data.min()))
    if peak > 0:
        audio_data = audio_data / peak * 0.95
    pcm16 = (audio_data * 32767).astype(np.int16)
    audio_bytes = pcm16.tobytes()
    print(f"[TEST] Audio : {len(pcm16)} echantillons, {len(audio_bytes)} bytes PCM16")

    print(f"[TEST] Connexion WebSocket : {url}")
    try:
        ws = await asyncio.wait_for(websockets.connect(url), timeout=15)
    except Exception as e:
        print(f"[TEST] ECHEC connexion : {e}")
        return False

    try:
        # 1. Attendre session.created
        msg_raw = await asyncio.wait_for(ws.recv(), timeout=30)
        msg = json.loads(msg_raw)
        if msg.get("type") == "error":
            print(f"[TEST] ECHEC : erreur serveur : {msg.get('error')}")
            return False
        print(f"[TEST] session.created : {msg.get('id', '?')}")

        # 2. session.update (REQUIRED before any commit)
        await ws.send(json.dumps({"type": "session.update", "model": model}))
        print(f"[TEST] session.update envoye : model={model}")
        await asyncio.sleep(0.5)

        # 3. audio en sous-chunks (append AVANT commit)
        total = len(audio_bytes)
        offset = 0
        n = 0
        while offset < total:
            chunk = audio_bytes[offset:offset + subchunk_size]
            offset += subchunk_size
            n += 1
            audio_b64 = base64.b64encode(chunk).decode("ascii")
            await ws.send(json.dumps({
                "type": "input_audio_buffer.append",
                "audio": audio_b64,
            }))
        print(f"[TEST] Audio envoye : {n} sous-chunks, {total} bytes")

        # 4. commit avec final=True pour signaler la fin de l'audio
        await ws.send(json.dumps({
            "type": "input_audio_buffer.commit",
            "final": True,
        }))

        # 6. collecter le texte
        deltas = []
        done_text = None
        while True:
            msg_raw = await asyncio.wait_for(ws.recv(), timeout=120)
            msg = json.loads(msg_raw)
            msg_type = msg.get("type")

            if msg_type == "transcription.delta":
                deltas.append(msg.get("delta", ""))
                print(f"[TEST] delta: {msg.get('delta', '')!r}")
            elif msg_type == "transcription.done":
                done_text = msg.get("text", "")
                print(f"[TEST] done: {done_text!r}")
                break
            elif msg_type == "error":
                print(f"[TEST] ECHEC : {msg.get('error')}")
                return False
            else:
                print(f"[TEST] event inconnu: {msg_type}")

        if done_text and done_text.strip():
            text = done_text
        elif deltas:
            text = "".join(deltas)
        else:
            text = ""

        print(f"[TEST] Transcription finale : {text!r}")
        success = len(text.strip()) > 0
        print(f"[TEST] {'SUCCES' if success else 'ECHEC (texte vide)'}")
        return success

    finally:
        await ws.close()


def main():
    parser = argparse.ArgumentParser(description="Test isole WebSocket vLLM Realtime")
    parser.add_argument("audio", help="Fichier audio WAV mono 16kHz")
    parser.add_argument("--host", default="localhost")
    parser.add_argument("--port", type=int, default=8000)
    parser.add_argument("--model", default="mistralai/Voxtral-Mini-4B-Realtime-2602")
    parser.add_argument("--subchunk", type=int, default=8192,
                        help="Taille des sous-chunks audio en bytes")
    args = parser.parse_args()

    if not os.path.exists(args.audio):
        print(f"ERREUR : fichier audio non trouve : {args.audio}")
        sys.exit(1)

    # Health check
    health_url = f"http://{args.host}:{args.port}/health"
    try:
        urllib.request.urlopen(health_url, timeout=3)
        print(f"[TEST] Health check OK : {health_url}")
    except Exception as e:
        print(f"[TEST] ECHEC health check : {health_url}")
        print(f"      Erreur : {e}")
        print("      Lancez d'abord : bash scripts/start_voxtral_realtime_vllm.sh")
        sys.exit(1)

    success = asyncio.run(test_realtime(
        args.host, args.port, args.audio, args.model, args.subchunk
    ))
    sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
